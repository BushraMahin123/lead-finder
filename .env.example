# AI Ark — https://docs.ai-ark.com/
AI_ARK_API_KEY=your_api_key_here

# Airscale — https://docs.airscale.io/api-reference/api-overview
AIRSCALE_API_KEY=your_api_key_here

# Supabase — https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here
# Google OAuth — enable in Supabase Dashboard → Authentication → Providers → Google
# Add redirect URL: http://localhost:3000/auth/callback (and your production URL)

# Database — Supabase Dashboard → Project Settings → Database
# Used by `pnpm db:migrate` to run SQL migrations locally.
SUPABASE_DB_PASSWORD=your_database_password_here

# Super admins — comma-separated Supabase user UUIDs with full admin access
SUPER_ADMIN_USER_IDS=your_user_uuid_here

# Waitlist mode — public visitors see the waitlist landing; self-serve signup is closed.
# Login stays available so invited accounts can sign in.
# Set to true in production until you're ready to open the app.
WAITLIST_MODE=true
# Developer unlock: visit /?access=<this-secret> once to unlock login/signup/app
# for that browser (sets an httpOnly cookie for 30 days).
WAITLIST_BYPASS_SECRET=change-me-to-a-long-random-string

# Transactional email (Resend) — used to send account credentials from the admin panel.
# https://resend.com/api-keys
RESEND_API_KEY=re_...
# Verified sender, e.g. "LEADMAGPRO <hello@yourdomain.com>"
# Defaults to Resend's test sender if unset (only delivers to your Resend account email).
EMAIL_FROM=LEADMAGPRO <hello@yourdomain.com>

# Gemini — https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_key_here
# GEMINI_MODEL=gemini-3.5-flash

# AI search limits (optional — defaults shown)
# AI_PARSE_RATE_LIMIT_PER_HOUR=60
# AI_PARSE_GEMINI_RATE_LIMIT_PER_HOUR=20
# AI_PARSE_CACHE_TTL_DAYS=30
# GEMINI_CIRCUIT_BREAKER_MINUTES=15

# External API queue (optional — defaults shown)
# Limits concurrent outbound calls per server instance; extra calls wait in a FIFO queue.
# API_QUEUE_AI_ARK_CONCURRENCY=3
# API_QUEUE_AIRSCALE_CONCURRENCY=2
# API_QUEUE_GEMINI_CONCURRENCY=2
# API_QUEUE_MAX_RETRIES=3
# API_QUEUE_RETRY_BASE_MS=1000

# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_APP_URL=http://localhost:3000
# In production, set this to your live URL (e.g. https://your-domain.com).
# Vercel also provides VERCEL_URL automatically if this is unset.

# Stripe Price IDs (create products/prices in Stripe Dashboard)
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_AGENCY=price_...
STRIPE_PRICE_TOPUP_SMALL=price_...
STRIPE_PRICE_TOPUP_MEDIUM=price_...
STRIPE_PRICE_TOPUP_LARGE=price_...
