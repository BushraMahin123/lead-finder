    "db:migrate:ai-parse": "node scripts/run-migration.mjs supabase/ai_parse.sql",
    "db:migrate:campaign-columns": "node scripts/run-migration.mjs supabase/campaign_columns.sql",
    "db:migrate:super-admins": "node scripts/run-migration.mjs supabase/super_admins.sql",
