    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.109.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "stripe": "^22.3.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "postgres": "^3.4.9",
    "tailwindcss": "^4",
    "typescript": "^5"
